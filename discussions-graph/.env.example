# Local dev defaults for discussions-graph. Copy to .env and customize.
# Values are gitignored once copied. In production, set these via your host's
# environment (Render dashboard, etc.) — never commit real secrets.

# ---- Inter-service URLs ----
# Local dev: services on different ports on localhost.
# Render single-container deploy: keep these as localhost (sidecars).
DISCUSSIONS_SERVICE_URL=http://localhost:4001
GENAI_SERVICE_URL=http://localhost:4002

# ---- Shared secret for graph↔genai handshake ----
# MUST match genai-service's INTERNAL_SERVICE_TOKEN exactly.
# Generate with: openssl rand -base64 32
INTERNAL_SERVICE_TOKEN=must-match-genai-service-token

# ---- CORS allowlist ----
# Production: set to your Vercel URL, e.g. https://anoncircles.vercel.app
UI_ORIGIN=http://localhost:5173
