# Local dev defaults for discussions-service. Copy to .env and customize.

# ---- Database ----
# Local: brew postgres, no password. Production: Neon pooled connection string.
# Example: jdbc:postgresql://ep-xxx-pooler.us-east-2.aws.neon.tech/anoncircles?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/anoncircles
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ---- JWT signing ----
# MUST be at least 32 bytes. Regenerate per environment.
# Generate with: openssl rand -base64 32
ENGAGE_AUTH_SECRET=replace-me-with-openssl-rand-base64-32
ENGAGE_AUTH_EXPIRATION=7d

# ---- CORS ----
# Production: the Vercel URL, e.g. https://anoncircles.vercel.app
APP_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGIN=http://localhost:5173
