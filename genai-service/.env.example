# Local dev defaults for genai-service. Copy to .env and customize.

# ---- Gemini API key (REQUIRED) ----
# Get a key from https://aistudio.google.com/apikey — service refuses to start
# without one. There is no fallback provider; missing key = startup failure.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ---- Shared secret for graph↔genai handshake ----
# MUST match discussions-graph's INTERNAL_SERVICE_TOKEN exactly.
# Generate with: openssl rand -base64 32
INTERNAL_SERVICE_TOKEN=replace-me-with-openssl-rand-base64-32
