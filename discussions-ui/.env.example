# Local dev defaults for discussions-ui. Copy to .env and customize.

# ---- GraphQL endpoint ----
# Local dev: BFF on localhost:4003.
# Production (Vercel): point at the public Render URL of discussions-graph,
# e.g. https://anoncircles-graph.onrender.com/graphql
# The Apollo client derives the WebSocket URL from this by swapping http→ws,
# so the same env var drives both transports.
VITE_GRAPHQL_URL=http://localhost:4003/graphql
